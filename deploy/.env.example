# ============================================================
# MilkShow — Variáveis de Ambiente
# Copie para /opt/milkshow/.env no servidor e preencha tudo
# ============================================================

# ── IA ──────────────────────────────────────────────────────
# Groq (gratuito) — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Google Gemini (gratuito) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (pago, fallback) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Firebase ────────────────────────────────────────────────
# Caminho para o arquivo da chave (copiar para o servidor)
GOOGLE_APPLICATION_CREDENTIALS=/opt/milkshow/firebase_key.json

# ── Evolution API ───────────────────────────────────────────
# URL pública do servidor (com https:// ou http://IP)
EVOLUTION_PUBLIC_URL=http://178.104.252.193
# Para Docker: bot roda no host; Evolution acessa via bridge network
EVOLUTION_URL=http://localhost:8080
EVOLUTION_KEY=milkshow2024
EVOLUTION_INSTANCE=milkshow
# URL do bot acessível DENTRO do Docker (bridge gateway do host)
BOT_URL=http://172.17.0.1:8000

# ── PostgreSQL (usado pelo Evolution API v2) ─────────────────
POSTGRES_PASSWORD=milkshow2024pg

# ── WhatsApp — providers alternativos (opcional) ─────────────
# Z-API (se usar em vez da Evolution)
# ZAPI_INSTANCE=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

# Twilio (último recurso)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=whatsapp:+14155238886
